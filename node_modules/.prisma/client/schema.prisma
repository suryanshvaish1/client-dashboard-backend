generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  PM
  DEV
}

enum Status {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  OVERDUE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  password String
  role     Role

  projects Project[] @relation("UserProjects")
}

model Project {
  id   String @id @default(uuid())
  name String

  createdBy   User   @relation("UserProjects", fields: [createdById], references: [id])
  createdById String
}

model Task {
  id          String   @id @default(uuid())
  title       String
  description String
  status      String
  priority    String
  dueDate     DateTime
  assignedTo  String
  projectId   String
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  message   String
  userId    Int
  taskId    Int
  createdAt DateTime @default(now())
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}
